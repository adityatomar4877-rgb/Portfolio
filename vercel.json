{
  "rewrites": [
    {
      "source": "/assets/(.*)",
      "destination": "/client/assets/$1"
    },
    {
      "source": "/resume.pdf",
      "destination": "/client/resume.pdf"
    },
    {
      "source": "/favicon.svg",
      "destination": "/client/favicon.svg"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ]
}